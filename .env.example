# Ambiente
APP_ENV=development

# Banco de dados (SQLite para dev, PostgreSQL para prod)
DATABASE_URL=sqlite+aiosqlite:///./rh.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/rh_db

# JWT — deve bater com o Core (G0)
JWT_SECRET=troque-este-secret-em-producao
JWT_ALGORITHM=HS256

# URL do Core para validação JWT
CORE_URL=http://localhost:8000

# Porta deste serviço
PORT=8002
